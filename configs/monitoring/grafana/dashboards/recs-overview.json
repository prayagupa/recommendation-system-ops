{
  "__inputs": [],
  "__requires": [],
  "annotations": { "list": [] },
  "description": "Recommendation System — Training & Serving Overview",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "Serving",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "ms"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "id": 2,
      "options": { "tooltip": { "mode": "single" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, rate(:tensorflow:serving:request_latency_bucket[5m])) / 1000",
          "legendFormat": "p99 latency",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.50, rate(:tensorflow:serving:request_latency_bucket[5m])) / 1000",
          "legendFormat": "p50 latency",
          "refId": "B"
        }
      ],
      "title": "Serving Latency (ms)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "reqps" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "id": 3,
      "targets": [
        {
          "expr": "rate(:tensorflow:serving:request_count[1m])",
          "legendFormat": "QPS",
          "refId": "A"
        }
      ],
      "title": "Requests per Second",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 4,
      "title": "Feature Store",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "bytes" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "id": 5,
      "targets": [
        {
          "expr": "redis_memory_used_bytes",
          "legendFormat": "Redis memory used",
          "refId": "A"
        }
      ],
      "title": "Feature Store Memory",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "ops" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "id": 6,
      "targets": [
        {
          "expr": "rate(redis_commands_processed_total[1m])",
          "legendFormat": "Redis ops/s",
          "refId": "A"
        }
      ],
      "title": "Feature Store Throughput",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["recs", "mlops"],
  "time": { "from": "now-1h", "to": "now" },
